# Lificosm Backend Environment Variables
# Copy this file to .env and fill in your values

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_here
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# TURN/STUN Server Configuration
TURN_SECRET=your_secure_turn_secret_here
TURN_SERVER_REALM=lificosm.com
TURN_SERVER_PORT=3478
STUN_SERVER_URL=stun.l.google.com:19302

# Database Configuration
DB_URL=jdbc:h2:mem:lificosmdb
DB_USERNAME=sa
DB_PASSWORD=password

# Kurento Media Server
KMS_URL=ws://localhost:8888/kurento

# Server Configuration
SERVER_PORT=8080
SERVER_ADDRESS=localhost

# Logging Configuration
LOG_LEVEL=DEBUG