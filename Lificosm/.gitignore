# Lificosm .gitignore

# Environment variables
.env
.env.local
.env.development
.env.production
.env.test
!frontend/.env.example

# Secrets
**/*secret*
**/*.pem
**/*.key
**/*.p12
**/*.jks

# Compiled class files
*.class
**/target/
**/build/
**/out/
**/dist/

# Log files
*.log
**/logs/

# Package files
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Maven
.mvn/wrapper/maven-wrapper.jar
**/mvnw
**/mvnw.cmd

# Gradle
.gradle
**/build/

# IDE files
.idea/
*.iml
*.ipr
*.iws
**/.classpath
**/.project
**/.settings/
**/.vscode/
**/.factorypath
**/*.launch
**/*.sublime-workspace
**/.nb-gradle/

# OS-specific files
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Application specific
/recordings/
/var/

# Node
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/package-lock.json
**/yarn.lock

# Testing
/coverage/
/.nyc_output/

# Production build files
**/build/
**/dist/
**/public/

# Debug files
**/*.stackdump

# Temporary files
**/tmp/
**/temp/